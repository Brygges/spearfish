process {
    resourceLimits = [
        cpus: 52,
        memory: '128.GB',
        time: '48.h'
    ]
}

profiles {
    singularity {
        singularity.cacheDir = "${projectDir}/singularity_cache"
    }
    apptainer {
        apptainer.cacheDir = "${projectDir}/singularity_cache"
    }
}

params {
    config_profile_name = 'Local (server) profile'
    config_profile_description = 'For test usage on KU HPC system'
}